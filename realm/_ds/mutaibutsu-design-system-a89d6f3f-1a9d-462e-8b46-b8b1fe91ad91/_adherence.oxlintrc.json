{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "audio/**",
              "components/core/**",
              "components/expanse/**",
              "components/lab/**",
              "components/narrative/**",
              "components/realm/**",
              "realm-visualiser/**",
              "ui_kits/engine-laboratory/**",
              "ui_kits/realm-observer/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Mochiy Pop One|Zen Kaku Gothic New|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Mochiy Pop One, Zen Kaku Gothic New, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|world|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, world, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='world'] > Literal[value!=/^(?:realm|lab)$/]",
        "message": "<Badge> world must be one of 'realm' | 'lab'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:show|travel|dayoff|error|neutral)$/]",
        "message": "<Badge> tone must be one of 'show' | 'travel' | 'dayoff' | 'error' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineBeat'] > JSXAttribute > JSXIdentifier[name!=/^(?:n|name|fn|pacing|rigidity|desc|key|ref|className|style|children)$/]",
        "message": "<TimelineBeat> doesn't accept that prop. Declared props: n, name, fn, pacing, rigidity, desc."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineBeat'] > JSXAttribute[name.name='fn'] > Literal[value!=/^(?:orientation|disruption|resistance|preparation|commitment|escalation|revelation|resolution)$/]",
        "message": "<TimelineBeat> fn must be one of 'orientation' | 'disruption' | 'resistance' | 'preparation' | 'commitment' | 'escalation' | 'revelation' | 'resolution'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineBeat'] > JSXAttribute[name.name='rigidity'] > Literal[value!=/^(?:hard|soft)$/]",
        "message": "<TimelineBeat> rigidity must be one of 'hard' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlueprintCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|source|evidence|scales|beats|conflict|description|selected|compact|onClick|style|key|ref|className|style|children)$/]",
        "message": "<BlueprintCard> doesn't accept that prop. Declared props: id, name, source, evidence, scales, beats, conflict, description, selected, compact, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlueprintCard'] > JSXAttribute[name.name='evidence'] > Literal[value!=/^(?:peer-reviewed|industry-validated|cultural-tradition)$/]",
        "message": "<BlueprintCard> evidence must be one of 'peer-reviewed' | 'industry-validated' | 'cultural-tradition'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|world|variant|size|icon|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, world, variant, size, icon, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='world'] > Literal[value!=/^(?:realm|lab)$/]",
        "message": "<Button> world must be one of 'realm' | 'lab'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|danger|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'danger' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CharacterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|mood|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<CharacterChip> doesn't accept that prop. Declared props: name, src, mood, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Campaign'] > JSXAttribute > JSXIdentifier[name!=/^(?:target_id|target_name|perpetrator_id|perpetrator_name|campaign_type|status|raw_potency|campaign_potency|impact_debility|impact_dependency|impact_dread|tick|key|ref|className|style|children)$/]",
        "message": "<Campaign> doesn't accept that prop. Declared props: target_id, target_name, perpetrator_id, perpetrator_name, campaign_type, status, raw_potency, campaign_potency, impact_debility, impact_dependency, impact_dread, tick."
      },
      {
        "selector": "JSXOpeningElement[name.name='EngineRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|name|desc|status|role|onClick|style|key|ref|className|style|children)$/]",
        "message": "<EngineRow> doesn't accept that prop. Declared props: index, name, desc, status, role, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EngineRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:wired|built|designed|stub|concept|orphan)$/]",
        "message": "<EngineRow> status must be one of 'wired' | 'built' | 'designed' | 'stub' | 'concept' | 'orphan'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EngineRow'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:ACT|PER|NAR)$/]",
        "message": "<EngineRow> role must be one of 'ACT' | 'PER' | 'NAR'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FunctionTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:fn|variant|size|glow|style|key|ref|className|style|children)$/]",
        "message": "<FunctionTag> doesn't accept that prop. Declared props: fn, variant, size, glow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FunctionTag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:dot|tag)$/]",
        "message": "<FunctionTag> variant must be one of 'dot' | 'tag'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeuristicCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:prompt|author|work|situation|beatContext|register|style|key|ref|className|style|children)$/]",
        "message": "<HeuristicCard> doesn't accept that prop. Declared props: prompt, author, work, situation, beatContext, register, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeuristicCard'] > JSXAttribute[name.name='register'] > Literal[value!=/^(?:instrument|mythic)$/]",
        "message": "<HeuristicCard> register must be one of 'instrument' | 'mythic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MonoLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<MonoLabel> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MonoLabel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:mute|accent|text|ink)$/]",
        "message": "<MonoLabel> tone must be one of 'mute' | 'accent' | 'text' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MutaiWisp'] > JSXAttribute > JSXIdentifier[name!=/^(?:leak|intensity|size|label|style|key|ref|className|style|children)$/]",
        "message": "<MutaiWisp> doesn't accept that prop. Declared props: leak, intensity, size, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:who|children|tail|style|key|ref|className|style|children)$/]",
        "message": "<SpeechBubble> doesn't accept that prop. Declared props: who, children, tail, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBubble'] > JSXAttribute[name.name='tail'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<SpeechBubble> tail must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechRung'] > JSXAttribute > JSXIdentifier[name!=/^(?:stage|pattern|example|key|ref|className|style|children)$/]",
        "message": "<SpeechRung> doesn't accept that prop. Declared props: stage, pattern, example."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechRung'] > JSXAttribute[name.name='stage'] > Literal[value!=/^(?:holophrastic|two_word|telegraphic|multiword|complex)$/]",
        "message": "<SpeechRung> stage must be one of 'holophrastic' | 'two_word' | 'telegraphic' | 'multiword' | 'complex'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sub|tone|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, sub, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|travel|dayoff|error|text)$/]",
        "message": "<StatCard> tone must be one of 'accent' | 'travel' | 'dayoff' | 'error' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|pulse|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, size, pulse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:wired|built|designed|stub|concept|orphan)$/]",
        "message": "<StatusDot> status must be one of 'wired' | 'built' | 'designed' | 'stub' | 'concept' | 'orphan'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|tone|key|ref|className|style|children)$/]",
        "message": "<TerminalLine> doesn't accept that prop. Declared props: text, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalLine'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:out|you|ok|warn|error)$/]",
        "message": "<TerminalLine> tone must be one of 'out' | 'you' | 'ok' | 'warn' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:show|message|state|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: show, message, state, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:running|success|error)$/]",
        "message": "<Toast> state must be one of 'running' | 'success' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='YureiPresence'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|hunger|breachAt|tick|style|key|ref|className|style|children)$/]",
        "message": "<YureiPresence> doesn't accept that prop. Declared props: mode, hunger, breachAt, tick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='YureiPresence'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:WITHDRAWN|BREACHED)$/]",
        "message": "<YureiPresence> mode must be one of 'WITHDRAWN' | 'BREACHED'."
      }
    ]
  },
